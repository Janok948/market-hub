# Copy to .env.local for local dev, and set these in the Vercel dashboard for production.
# NEVER commit real values — .env files are gitignored.

# Your production domain. Used by build.js for canonical URLs, sitemap, and Open Graph.
SITE_URL=https://yourdomain.com

# Supabase (only needed for the /api/subscribe newsletter function).
# Get these from: Supabase dashboard -> Project Settings -> API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SERVICE ROLE key — server-side only. It bypasses Row-Level Security, so it must
# never be exposed in client code or committed. It lives only in Vercel env vars.
SUPABASE_SERVICE_KEY=your-service-role-key
